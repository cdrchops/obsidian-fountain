{
	"name": "obsidian-fountain-plugin",
	"version": "0.34.0",
	"description": "This is a fountain plugin for obsidian",
	"main": "main.js",
	"scripts": {
		"predev": "npm run parser",
		"prebuild": "npm run parser",
		"pretest": "npm run parser",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"parser": "peggy -c peggy_config.mjs",
		"test": "jest",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"local-deploy": "mkdir -p test-vault/.obsidian/plugins/fountain && cp manifest.json main.js styles.css test-vault/.obsidian/plugins/fountain"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.0",
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.2",
		"@codemirror/language": "^6.12.2",
		"@codemirror/state": "^6.5.4",
		"@jest/globals": "^30.2.0",
		"@types/jest": "^30.0.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.3.5",
		"@wdio/cli": "^9.24.0",
		"@wdio/local-runner": "^9.24.0",
		"@wdio/mocha-framework": "^9.24.0",
		"babel-jest": "^29.7.0",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.27.3",
		"jest": "^30.2.0",
		"mocha": "^11.7.5",
		"obsidian": "^1.12.3",
		"peggy": "^5.1.0",
		"ts-jest": "^29.4.6",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"wdio-obsidian-reporter": "^2.3.3",
		"wdio-obsidian-service": "^2.3.3"
	},
	"dependencies": {
		"@codemirror/search": "^6.5.0",
		"jest-environment-jsdom": "^30.2.0",
		"pdf-lib": "^1.17.1"
	}
}
